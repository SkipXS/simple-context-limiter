{
  "name": "simple-context-limiter",
  "version": "1.1.0",
  "description": "Minimal MCP server that bounds command/log, file, search, repo discovery, web, git diff, and usage output for LLM context",
  "type": "module",
  "main": "server.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SkipXS/simple-context-limiter.git"
  },
  "homepage": "https://github.com/SkipXS/simple-context-limiter#readme",
  "bugs": {
    "url": "https://github.com/SkipXS/simple-context-limiter/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "server.js",
    "src/",
    "scripts/",
    "check-syntax.js",
    "smoke-test.js",
    "pack-smoke-test.js",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "node check-syntax.js && npm run test:unit && node scripts/output-quality-check.js",
    "quality": "node scripts/output-quality-check.js",
    "coverage": "node --test --experimental-test-coverage test/*.test.js",
    "test": "npm run test:unit && npm run test:smoke",
    "test:unit": "node --test test/*.test.js",
    "test:smoke": "node smoke-test.js",
    "audit": "npm audit --omit=dev",
    "release:check": "npm pack --dry-run --ignore-scripts && node pack-smoke-test.js",
    "prepack": "node check-syntax.js",
    "prepublishOnly": "npm run check && npm run release:check"
  },
  "bin": { "simple-context-limiter": "server.js" },
  "license": "MIT"
}
